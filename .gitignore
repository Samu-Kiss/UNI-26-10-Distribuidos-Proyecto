# Python cache and local runtime artifacts
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environments and local environment files
.venv/
venv/
env/
ENV/
.env
.env.*

# Local Codex/agent metadata
.codex/
.agents/

# Local IDE/editor metadata
.idea/
.vscode/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Runtime SQLite databases generated by the distributed simulation
*.sqlite
*.sqlite3
*.sqlite-journal
*.sqlite3-journal
*.sqlite-shm
*.sqlite-wal
*.sqlite3-shm
*.sqlite3-wal

# Logs and temporary runtime output
*.log
logs/
tmp/
temp/

# LaTeX generated files.
# Keep source .tex, generated .pdf, and diagram/image assets versioned.
*.aux
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.lof
*.lot
*.nav
*.out
*.run.xml
*.snm
*.synctex
*.synctex.gz
*.toc
*.vrb
*.xdv

# Keep these LaTeX deliverables/assets explicitly trackable
!*.tex
!*.pdf
!*.png
!*.jpg
!*.jpeg
!*.svg
!*.mmd
!*.mermaid
